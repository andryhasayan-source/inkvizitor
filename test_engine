class TestFinding(unittest.TestCase):

    def test_finding_minimal(self):
        f = Finding(kind="zero_width", severity="high", title_key="check.zw")
        self.assertEqual(f.kind, "zero_width")
        self.assertEqual(f.severity, "high")
        self.assertIsNone(f.line)

    def test_finding_with_location(self):
        f = Finding(kind="secret", severity="critical",
                    title_key="check.secret", line=42, column=7)
        self.assertEqual(f.line, 42)
        self.assertEqual(f.column, 7)

    def test_finding_extra_defaults_to_empty_dict(self):
        f = Finding(kind="x", severity="info", title_key="k")
        self.assertEqual(f.extra, {})


# ---------------------------------------------------------------------------
# Tests: FileReport
# ---------------------------------------------------------------------------

class TestFileReport(unittest.TestCase):

    def _make_report(self, severities: list[str]) -> FileReport:
        report = FileReport(path="test.py", encoding="utf-8")
        for sev in severities:
            report.findings.append(
                Finding(kind="test", severity=sev, title_key="k")
            )
        return report

    def test_empty_report_is_green(self):
        report = FileReport(path="clean.py", encoding="utf-8")
        self.assertEqual(report.status, "green")
        self.assertEqual(report.max_severity, "info")

    def test_low_finding_is_yellow(self):
        report = self._make_report(["low"])
        self.assertEqual(report.status, "yellow")

    def test_medium_finding_is_yellow(self):
        report = self._make_report(["medium"])
        self.assertEqual(report.status, "yellow")

    def test_high_finding_is_red(self):
        report = self._make_report(["high"])
        self.assertEqual(report.status, "red")

    def test_critical_finding_is_red(self):
        report = self._make_report(["critical"])
        self.assertEqual(report.status, "red")

    def test_max_severity_picks_worst(self):
        report = self._make_report(["low", "critical", "medium"])
        self.assertEqual(report.max_severity, "critical")

    def test_threats_counts_high_and_critical(self):
        report = self._make_report(["info", "low", "medium", "high", "critical"])
        self.assertEqual(report.threats, 2)

    def test_author_marks_counted_by_kind(self):
        report = FileReport(path="f.py", encoding="utf-8")
        report.findings.append(Finding(kind="author_mark", severity="info", title_key="k"))
        report.findings.append(Finding(kind="zero_width", severity="high", title_key="k"))
        self.assertEqual(report.author_marks, 1)

    def test_no_author_marks_in_clean_file(self):
        report = self._make_report(["low", "medium"])
        self.assertEqual(report.author_marks, 0)


# ---------------------------------------------------------------------------
# Tests: SEVERITY_ORDER
# ---------------------------------------------------------------------------

class TestSeverityOrder(unittest.TestCase):

    def test_critical_is_highest(self):
        self.assertGreater(SEVERITY_ORDER["critical"], SEVERITY_ORDER["high"])

    def test_info_is_lowest(self):
        self.assertEqual(min(SEVERITY_ORDER.values()),
                         SEVERITY_ORDER["info"])

    def test_all_five_levels_present(self):
        self.assertEqual(set(SEVERITY_ORDER.keys()),
                         {"info", "low", "medium", "high", "critical"})


# ---------------------------------------------------------------------------
# Tests: zero-width detector
# ---------------------------------------------------------------------------

class TestZeroWidthDetector(unittest.TestCase):

    def test_clean_file_no_findings(self):
        source = "print('hello')\n# normal comment\n"
        self.assertEqual(detect_zero_width(source), [])

    def test_detects_zwsp(self):
        source = "x = 1  \u200b # invisible char here\n"
        findings = detect_zero_width(source)
        self.assertEqual(len(findings), 1)
        self.assertEqual(findings[0].severity, "high")
        self.assertEqual(findings[0].kind, "zero_width")

    def test_detects_multiple_zw_chars(self):
        source = "\u200b\u200c\u200d on one line\n"
        findings = detect_zero_width(source)
        self.assertEqual(len(findings), 3)

    def test_reports_correct_line_number(self):
        source = "clean line\n\u200b hidden here\n"
        findings = detect_zero_width(source)
        self.assertEqual(findings[0].line, 2)

    def test_reports_unicode_codepoint_in_detail(self):
        source = "\u200b\n"
        findings = detect_zero_width(source)
        self.assertIn("200B", findings[0].detail)


# ---------------------------------------------------------------------------
# Tests: secret detector
# ---------------------------------------------------------------------------

class TestSecretDetector(unittest.TestCase):

    def test_clean_file_no_secrets(self):
        source = "API_KEY = 'not_a_real_key'\n"
        self.assertEqual(detect_secrets(source), [])

    def test_detects_aws_key(self):
        source = "key = 'AKIAIOSFODNN7EXAMPLE'\n"
        findings = detect_secrets(source)
        self.assertTrue(any(f.kind == "secret" for f in findings))
        self.assertTrue(any(f.severity == "critical" for f in findings))

    def test_detects_telegram_token(self):
        source = "TOKEN = '1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi'\n"
        findings = detect_secrets(source)
        self.assertTrue(any("telegram" in f.title_key for f in findings))

    def test_reports_correct_line_for_secret(self):
        source = "clean\nclean\nTOKEN = '1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi'\n"
        findings = detect_secrets(source)
        self.assertEqual(findings[0].line, 3)


