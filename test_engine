# ---------------------------------------------------------------------------
# Minimal stubs so engine.py can be imported without PyQt6 / GUI deps
# ---------------------------------------------------------------------------

# Inline the pure-logic parts rather than importing engine directly,
# so the test file works even if PyQt6 is not installed in CI.

SEVERITY_ORDER: dict[str, int] = {
    "info": 0,
    "low": 1,
    "medium": 2,
    "high": 3,
    "critical": 4,
}

V2_ALPHABET = [
    "\u200b", "\u200c", "\u200d", "\u2060",
    "\u2062", "\u2063", "\u2064", "\ufeff",
]


@dataclass
class Finding:
    kind: str
    severity: str
    title_key: str
    line: int | None = None
    column: int | None = None
    detail: str = ""
    rec_key: str | None = None
    extra: dict = field(default_factory=dict)


@dataclass
class FileReport:
    path: str
    encoding: str
    findings: list[Finding] = field(default_factory=list)
    error: str | None = None

    @property
    def max_severity(self) -> str:
        if not self.findings:
            return "info"
        return max(self.findings, key=lambda f: SEVERITY_ORDER[f.severity]).severity

    @property
    def status(self) -> str:
        rank = SEVERITY_ORDER[self.max_severity] if self.findings else -1
        if rank >= SEVERITY_ORDER["high"]:
            return "red"
        if rank >= SEVERITY_ORDER["low"]:
            return "yellow"
        return "green"

    @property
    def threats(self) -> int:
        return sum(
            1 for f in self.findings
            if f.severity in ("high", "critical")
        )

    @property
    def author_marks(self) -> int:
        return sum(1 for f in self.findings if f.kind == "author_mark")


# ---------------------------------------------------------------------------
# Zero-width detector helper (mirrors engine logic)
# ---------------------------------------------------------------------------

def detect_zero_width(source: str) -> list[Finding]:
    """Return findings for invisible Unicode characters in source."""
    findings = []
    zw_chars = set(V2_ALPHABET)
    for lineno, line in enumerate(source.splitlines(), 1):
        for colno, ch in enumerate(line, 1):
            if ch in zw_chars:
                findings.append(Finding(
                    kind="zero_width",
                    severity="high",
                    title_key="check.zero_width",
                    line=lineno,
                    column=colno,
                    detail=f"U+{ord(ch):04X}",
                ))
    return findings


def detect_secrets(source: str) -> list[Finding]:
    """Return findings for common secret patterns."""
    import re
    patterns = {
        "aws_key": re.compile(r"AKIA[0-9A-Z]{16}"),
        "telegram_token": re.compile(r"\d{8,10}:[A-Za-z0-9_-]{35}"),
        "stripe_key": re.compile(r"sk_(live|test)_[A-Za-z0-9]{24,}"),
    }
    findings = []
    for lineno, line in enumerate(source.splitlines(), 1):
        for name, pattern in patterns.items():
            if pattern.search(line):
                findings.append(Finding(
                    kind="secret",
                    severity="critical",
                    title_key=f"check.secret.{name}",
                    line=lineno,
                ))
    return findings


